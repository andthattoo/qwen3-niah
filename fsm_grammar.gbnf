# Minimal structured plan for code reasoning — one line per section.
# Kept deliberately simple to avoid edge cases in llama.cpp's GBNF engine.
# Grammar applies to the full assistant response; code after </think>
# is constrained to a permissive-but-plain character class.

root ::= "<think>\n"
         "GOAL: "     line
         "APPROACH: " line
         "EDGE: "     line
         "</think>\n\n"
         code

line ::= [^\n]+ "\n"

# Permissive code section — ASCII printable + whitespace.
# Avoid hex-escape char classes (some llama.cpp builds crash on those).
code ::= ( [a-zA-Z0-9] | [ \t\n\r] | [!@#$%^&*()_+\-={}\[\]\\|;:'\",.<>/?`~] )+
