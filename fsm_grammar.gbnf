# Terse structured plan for code reasoning — one line per section.
# Each rule MUST be on a single line (llama.cpp's GBNF parser doesn't
# accept rules split across multiple lines).

root ::= think code
think ::= "<think>\n" "GOAL: " line "APPROACH: " line "EDGE: " line "</think>\n\n"
line ::= [^\n]+ "\n"
code ::= ( [a-zA-Z0-9] | [ \t\n\r] | [!@#$%^&*()_+\-={}\[\]\\|;:'\",.<>/?`~] )+
